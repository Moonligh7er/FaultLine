# ============================================================
# FixThisFaster — Environment Variables (CLIENT-SIDE ONLY)
# ============================================================
# This file contains ONLY public/publishable keys safe for the client.
# Secret keys (Resend, Anthropic, Service Role) belong in
# Supabase Edge Function secrets ONLY — never here.
# ============================================================

# --- Supabase (publishable key only — safe for client) ---
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your_publishable_key_here

# --- AdMob ---
ADMOB_APP_ID_ANDROID=ca-app-pub-xxxxxxxxxxxxxxxx~yyyyyyyyyy
ADMOB_APP_ID_IOS=ca-app-pub-xxxxxxxxxxxxxxxx~yyyyyyyyyy
ADMOB_BANNER_ID_ANDROID=ca-app-pub-xxxxxxxxxxxxxxxx/zzzzzzzzzz
ADMOB_BANNER_ID_IOS=ca-app-pub-xxxxxxxxxxxxxxxx/zzzzzzzzzz

# --- Sentry (crash reporting) ---
SENTRY_DSN=https://your_dsn@sentry.io/project_id
SENTRY_ORG=your_sentry_org
SENTRY_PROJECT=your_sentry_project

# --- EAS (Expo Application Services) ---
EAS_PROJECT_ID=your_eas_project_id
