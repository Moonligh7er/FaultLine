# ============================================================
# Fault Line (mobile + marketing site) — private repo
# ============================================================
# This repo contains the Expo/RN mobile app source, the static
# marketing site, Supabase migrations, store metadata, and all
# project docs. The `.env` file is excluded so real keys never
# end up in git — use `.env.example` as the template instead.
# ============================================================

# Dependencies
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Expo
.expo/
.expo-shared/
expo-env.d.ts

# Build outputs
dist/
web-build/
build/
*.tsbuildinfo

# Native build folders
android/.gradle/
android/build/
android/app/build/
android/captures/
ios/build/
ios/Pods/
ios/*.xcworkspace
ios/*.xcuserdata/

# Native credentials — NEVER commit
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.keystore

# Env files — NEVER commit real keys
.env
.env.local
.env.*.local
.env.production

# `.env.example` IS tracked (it's the template)
!.env.example

# EAS
.easignore

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# IDE / editor
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Playwright / Vitest (from sibling fault-line-web — safety net)
test-results/
playwright-report/
playwright/.cache/
coverage/

# Temporary
*.tmp
tmp/
supabase/.temp/

# Image-pipeline working files (source renders + internal preview/review HTML).
# The approved set is committed under website/og/, website/blog-heroes/,
# website/social/, website/twitch/, store-metadata/, and assets/.
# image-subjects.json (source-of-truth) and the .mjs pipeline scripts ARE tracked.
generated-images/
flux1-prompts-preview.html
image-review.html
scripts/prompts.json
scripts/decisions.txt
